<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <Button
        android:id="@+id/btnPickFolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose Image Folder"
        android:layout_alignParentTop="true"/>

    <GridView
        android:id="@+id/myPhotoGrid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnPickFolder"
        android:layout_above="@id/btnOpenCam"
        android:numColumns="3"
        android:verticalSpacing="8dp"
        android:horizontalSpacing="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnOpenCam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Take New Photo"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"/>

</RelativeLayout>